# Empty = gRPC-Web uses the page origin (Vite proxies /kw_agent_service → Envoy). Use this for LAN access via http://<your-ip>:5173.
# Set to http://localhost:8080 only if you intentionally bypass the dev proxy.
VITE_API_BASE_URL=
VITE_BFF_BASE_URL=http://127.0.0.1:8201
VITE_BFF_TOKEN=
VITE_DEV_USER_ID=
VITE_DEV_LANE=
VITE_APP_ID=zy-bgnes
# Optional: local slide workspace root for dev preview
AGNES_LOCAL_SLIDE_WORKSPACE_ROOT=/Users/au/Documents/agnes_core/services/kw-agent-service/.super_agent/workspace
