# gRPC endpoint (optional, defaults to agnesx-dev-sg.kiwiar.com:443)
# Uncomment below to use local gRPC via Docker Envoy:
# VITE_API_BASE_URL=http://localhost:8080
VITE_BFF_BASE_URL=http://127.0.0.1:8201
# BFF Bearer；线上建议在 CI 中 export VITE_BFF_TOKEN=... 后执行 npm run build，勿把密钥提交进仓库
VITE_BFF_TOKEN=
VITE_DEV_USER_ID=
VITE_DEV_LANE=
VITE_APP_ID=zy-bgnes
# 设 true 后 ChatStream 会带 billing_enabled=true，让后端走真实 GrpcReservationClient（扣 credits）
# 缺省 / false / 不设 → 后端 NULL_RESERVATION_CLIENT no-op
VITE_BILLING_ENABLED=
